# Supabase — powers the world leaderboard + Google sign-in.
#
# Copy this file to `.env` and fill in the values from your Supabase project
# (Project Settings → API). Both vars are PUBLIC_-prefixed because Astro only
# exposes PUBLIC_* to client-side code via import.meta.env.
#
# The anon key is PUBLIC BY DESIGN — it is safe to ship in a static site.
# Security is enforced server-side by Row Level Security + the security-definer
# submit_score() function (see supabase/migrations/0001_leaderboard.sql), NOT by
# keeping this key secret. Do NOT put the service_role key here.
#
# If these are left unset, the app still builds and the game still plays — the
# leaderboard simply shows a "not set up yet" state.

PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
