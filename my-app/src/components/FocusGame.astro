---
// FocusGame — the full game surface.
// Four phases live inside one <focus-game> custom element; only one
// <section data-phase> is visible at a time. All logic ships in the
// <script> below (bundled + typed by Astro).
---

<focus-game class="block w-full">
	<!-- ============================================================
	     PHASE 1 · SETUP — choose the hold duration (10s → 12hr)
	     ============================================================ -->
	<section data-phase="setup" class="min-h-[88vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-4 uppercase tracking-[0.04em]">The focus game</p>
		<h1 class="text-hero text-ink max-w-[18ch]"><span class="whitespace-nowrap">Hold The Words</span><br /><span class="whitespace-nowrap">Measure Your Focus</span></h1>
		<p class="text-lead text-ink-muted-80 mt-5 max-w-[42ch]">
			A new word appears at the pace you choose. Keep them in order in your
			mind. When the timer ends, <span class="whitespace-nowrap">recall the sequence.</span>
		</p>

		<!-- Duration presets -->
		<div class="mt-12 w-full max-w-130">
			<p class="text-caption text-ink-muted-48 mb-3">Choose how long to hold your attention</p>
			<div role="group" aria-label="Duration presets" class="flex flex-wrap justify-center gap-2">
				<button type="button" class="preset" data-seconds="10">10 sec</button>
				<button type="button" class="preset" data-seconds="20">20 sec</button>
				<button type="button" class="preset" data-seconds="30">30 sec</button>
				<button type="button" class="preset" data-seconds="60">1 min</button>
				<button type="button" class="preset" data-seconds="180">3 min</button>
				<button type="button" class="preset" data-seconds="300">5 min</button>
			</div>

			<div class="mt-8 flex flex-col sm:flex-row sm:items-start justify-center gap-8 sm:gap-20">
			<!-- Custom duration -->
			<div>
				<p class="text-caption text-ink-muted-48 mb-3">Or set a custom time</p>
				<div class="flex items-end justify-center gap-3">
					<label class="flex flex-col items-center gap-1.5">
						<input type="number" min="0" max="12" value="0" data-unit="hours" class="time-input" />
						<span class="text-fine text-ink-muted-48">hours</span>
					</label>
					<span class="text-lead text-hairline pb-6 select-none">:</span>
					<label class="flex flex-col items-center gap-1.5">
						<input type="number" min="0" max="59" value="0" data-unit="minutes" class="time-input" />
						<span class="text-fine text-ink-muted-48">min</span>
					</label>
					<span class="text-lead text-hairline pb-6 select-none">:</span>
					<label class="flex flex-col items-center gap-1.5">
						<input type="number" min="0" max="59" value="30" data-unit="seconds" class="time-input" />
						<span class="text-fine text-ink-muted-48">sec</span>
					</label>
				</div>
				<p data-duration-hint class="text-fine text-ink-muted-48 mt-4" aria-live="polite"></p>
			</div>

			<!-- Word pace — how often a new word appears (1s → 3min) -->
			<div>
				<p class="text-caption text-ink-muted-48 mb-3">How often a new word appears</p>
				<div class="flex items-end justify-center gap-3">
					<label class="flex flex-col items-center gap-1.5">
						<input type="number" min="0" max="3" value="0" data-pace-unit="minutes" class="time-input" />
						<span class="text-fine text-ink-muted-48">min</span>
					</label>
					<span class="text-lead text-hairline pb-6 select-none">:</span>
					<label class="flex flex-col items-center gap-1.5">
						<input type="number" min="0" max="59" value="3" data-pace-unit="seconds" class="time-input" />
						<span class="text-fine text-ink-muted-48">sec</span>
					</label>
				</div>
				<p data-pace-hint class="text-fine text-ink-muted-48 mt-4" aria-live="polite"></p>
			</div>
			</div>
		</div>

		<div class="mt-12">
			<button type="button" data-action="start" class="btn-primary">Begin</button>
		</div>
	</section>

	<!-- ============================================================
	     PHASE 2 · WATCH — one word at a time, edge-to-edge dark tile
	     ============================================================ -->
	<section data-phase="watch" hidden class="fixed inset-0 z-50 bg-surface-tile-1 text-body-on-dark flex flex-col">
		<!-- thin progress line in Action Blue -->
		<div class="h-0.75 w-full bg-[rgba(255,255,255,0.12)]">
			<div data-progress class="h-full bg-primary-on-dark transition-[width] duration-200 ease-linear" style="width:0%"></div>
		</div>

		<div class="flex items-center justify-between px-6 py-5">
			<span data-clock class="text-caption text-body-muted tabular-nums">0:30</span>
			<span data-seen-count class="text-caption text-body-muted tabular-nums">0 words</span>
		</div>

		<div class="flex-1 flex items-center justify-center px-6">
			<span data-word class="text-display-lg text-body-on-dark" style="font-size:clamp(40px,9vw,88px)">&nbsp;</span>
		</div>

		<div class="px-6 py-8 flex justify-center">
			<button type="button" data-action="end-early" class="end-early-btn text-caption">End early &amp; recall now</button>
		</div>
	</section>

	<!-- ============================================================
	     PHASE 3 · RECALL — type the sequence back, in order
	     ============================================================ -->
	<section data-phase="recall" hidden class="min-h-[88vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-4 uppercase tracking-[0.04em]">Recall</p>
		<h2 class="text-display-lg text-ink max-w-[18ch]">Tap the words in the order they appeared.</h2>
		<p class="text-lead text-ink-muted-80 mt-4 max-w-[38ch]">Each correct word extends your focus span. One wrong tap ends the round.</p>

		<!-- Recall window = double the chosen hold. When it ends, the round ends. -->
		<p data-recall-clock class="text-caption text-primary tabular-nums mt-5" aria-live="polite">0:00 left to recall</p>

		<!-- the order you've rebuilt so far -->
		<p data-chosen-caption class="text-fine text-ink-muted-48 mt-8 uppercase tracking-[0.04em]">Chosen sequence so far · 0 of 0</p>
		<ul data-recall-list class="mt-3 flex flex-wrap justify-center gap-2 min-h-10" aria-live="polite"></ul>

		<!-- shuffled inbox of the words you saw -->
		<p class="text-fine text-ink-muted-48 mt-8 uppercase tracking-[0.04em]">Tap the words you saw</p>
		<div data-pool class="mt-3 flex flex-wrap justify-center gap-2.5 max-w-170" role="group" aria-label="Word choices"></div>
	</section>

	<!-- ============================================================
	     PHASE 4 · RESULT — attention span (time held) + focus (% recalled)
	     ============================================================ -->
	<section data-phase="result" hidden class="min-h-[88vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-2 uppercase tracking-[0.04em]">Your results</p>

		<!-- Two headline metrics, side by side -->
		<div class="mt-6 flex flex-wrap items-start justify-center gap-x-16 gap-y-10">
			<!-- Attention span = how long you held the timer -->
			<div class="flex flex-col items-center">
				<span data-attention class="text-ink" style="font-family:var(--font-display);font-weight:600;font-size:clamp(56px,13vw,120px);line-height:1;letter-spacing:-0.02em">0s</span>
				<span class="text-lead text-ink-muted-48 mt-2">Attention span</span>
				<span class="text-caption text-ink-muted-48 mt-1">time you held focus</span>
			</div>
			<!-- Focus = % of the sequence rebuilt correctly -->
			<div class="flex flex-col items-center">
				<span data-focus class="text-primary" style="font-family:var(--font-display);font-weight:600;font-size:clamp(56px,13vw,120px);line-height:1;letter-spacing:-0.02em">0%</span>
				<span class="text-lead text-ink-muted-48 mt-2">Focus</span>
				<span data-focus-detail class="text-caption text-ink-muted-48 mt-1">0 of 0 words in order</span>
			</div>
		</div>

		<p data-score-line class="text-lead text-ink-muted-80 mt-10 max-w-[36ch]"></p>
		<p data-best-line class="text-caption text-ink-muted-48 mt-3"></p>

		<!-- The reveal: what was actually shown vs. what you guessed -->
		<div class="mt-12 w-full max-w-160 text-left">
			<p class="text-caption text-ink-muted-48 mb-3">The sequence</p>
			<div data-reveal-list class="flex flex-wrap items-center gap-2"></div>
		</div>

		<div class="mt-12 flex items-center gap-3">
			<button type="button" data-action="again" class="btn-primary">Play again</button>
			<button type="button" data-action="change-time" class="btn-ghost">Change duration</button>
		</div>
	</section>
</focus-game>

<style>
	/* Setup duration preset chips — pill grammar, Action Blue when chosen */
	.preset {
		font-family: var(--font-text);
		font-size: 14px;
		letter-spacing: -0.224px;
		color: var(--color-ink);
		background-color: var(--color-canvas-parchment);
		border: 1px solid transparent;
		border-radius: var(--radius-pill);
		padding: 10px 18px;
		cursor: pointer;
		transition: transform 0.18s ease, background-color 0.18s ease, color 0.18s ease;
	}
	.preset:active { transform: scale(0.95); }
	.preset:focus-visible { outline: 2px solid var(--color-primary-focus); outline-offset: 2px; }
	.preset[aria-pressed="true"] {
		background-color: var(--color-primary);
		color: var(--color-on-primary);
	}

	/* End-early action — filled blue with a blue border, on the dark watch screen */
	.end-early-btn {
		background-color: var(--color-primary);
		color: var(--color-on-primary);
		border: 1px solid var(--color-primary);
		border-radius: var(--radius-pill);
		padding: 10px 18px;
		font-family: var(--font-text);
		font-weight: 500;
		cursor: pointer;
		transition: transform 0.18s ease, background-color 0.18s ease;
	}
	.end-early-btn:hover { background-color: color-mix(in srgb, var(--color-primary) 88%, #000); }
	.end-early-btn:active { transform: scale(0.96); }
	.end-early-btn:focus-visible { outline: 2px solid var(--color-primary-focus); outline-offset: 2px; }

	/* Numeric time inputs — quiet, hairline-bottom, big tabular figures */
	.time-input {
		width: 84px;
		text-align: center;
		font-family: var(--font-display);
		font-size: 34px;
		font-weight: 600;
		letter-spacing: -0.374px;
		color: var(--color-ink);
		background: transparent;
		border: none;
		border-bottom: 2px solid var(--color-hairline);
		padding: 4px 0 8px;
		font-variant-numeric: tabular-nums;
		-moz-appearance: textfield;
		appearance: textfield;
	}
	.time-input::-webkit-outer-spin-button,
	.time-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
	.time-input:focus { outline: none; border-bottom-color: var(--color-primary); }

	/* Recall pool — tappable words. Words you saw → blue text, no fill.
	   :global() because these tiles are created in JS, so Astro's scoped
	   class marker never lands on them. */
	:global(.pool-word) {
		font-family: var(--font-text);
		font-size: 17px;
		letter-spacing: -0.374px;
		color: var(--color-primary);
		background-color: transparent;
		border: none;
		padding: 8px 12px;
		cursor: pointer;
		transition: transform 0.14s ease, color 0.18s ease, opacity 0.18s ease;
	}
	:global(.pool-word:hover) { text-decoration: underline; }
	:global(.pool-word:active) { transform: scale(0.95); }
	:global(.pool-word:focus-visible) { outline: 2px solid var(--color-primary-focus); outline-offset: 2px; }
	:global(.pool-word:disabled) { cursor: default; }
	:global(.pool-word.is-wrong) {
		color: var(--color-ink-muted-48);
		text-decoration: line-through;
	}
	:global(.pool-word.is-dim) { opacity: 0.32; }

	/* Word chips in recall + reveal — also JS-created, so :global(). */
	:global(.chip) {
		font-family: var(--font-text);
		font-size: 14px;
		letter-spacing: -0.224px;
		padding: 8px 12px;
		background-color: transparent;
		color: var(--color-ink);
	}
	:global(.chip-correct) { color: var(--color-success); }
	:global(.chip-wrong) { color: var(--color-ink-muted-48); text-decoration: line-through; }
	:global(.chip-missed) { color: var(--color-ink-muted-48); }

	/* Arrow joining words in the result reveal → reads as one sequence */
	:global(.reveal-arrow) {
		font-family: var(--font-text);
		font-size: 14px;
		color: var(--color-ink-muted-48);
		user-select: none;
	}
</style>

<script>
	import { randomWord } from "../scripts/words";
	import { submitBest, fetchMyBest } from "../lib/leaderboard";

	const DEFAULT_WORD_INTERVAL_MS = 3000; // a fresh word every three seconds
	const MIN_WORD_INTERVAL_MS = 1000; // fastest pace: 1 s
	const MAX_WORD_INTERVAL_MS = 3 * 60 * 1000; // slowest pace: 3 min
	const MIN_SECONDS = 10;
	const MAX_SECONDS = 12 * 60 * 60; // 12 hours

	type Phase = "setup" | "watch" | "recall" | "result";

	class FocusGame extends HTMLElement {
		// --- run state ---
		private durationSec = 30;
		private wordIntervalMs = DEFAULT_WORD_INTERVAL_MS; // pace chosen at setup
		private shown: string[] = [];
		private guesses: string[] = [];
		private recallIndex = 0; // next position the player must match
		private wrongPick: string | null = null; // the tap that broke the chain, for the reveal
		private attentionSec = 0; // seconds the timer actually held, for the result
		private wordTimer: number | null = null;
		private countdownTimer: number | null = null;
		private recallTimer: number | null = null; // recall window = 2× hold
		private endsAt = 0;
		private recallEndsAt = 0;
		private recallStartedAt = 0;
		private recallSec = 0; // how long the player took to rebuild, for the best score

		// Personal best — sourced from the server per account, held in memory only.
		// NOT localStorage: that's one shared bucket per browser, so it would show
		// one account's best to the next account signed in on the same machine.
		private bestWords = 0;
		private bestAttentionSec = 0;
		private bestRecallSec = 0;

		connectedCallback() {
			this.bindSetup();
			this.bindWatch();
			this.bindRecall();
			this.bindResult();
			this.syncDurationHint();
			this.syncPaceHint();
			this.loadBest();
		}

		// Seed the in-memory best from the server (per account). Refreshes when the
		// player signs in/out so a new account never inherits the previous best.
		private async loadBest() {
			const apply = async () => {
				const best = await fetchMyBest();
				this.bestWords = best?.words ?? 0;
				this.bestAttentionSec = best?.attentionSec ?? 0;
				this.bestRecallSec = best?.recallSec ?? 0;
			};
			void apply();
			window.addEventListener("focus-attention:auth-changed", () => void apply());
		}

		// ---- phase switching ----
		private show(phase: Phase) {
			this.querySelectorAll<HTMLElement>("[data-phase]").forEach((el) => {
				el.hidden = el.dataset.phase !== phase;
			});
			// Dark watch tile wants a dark page behind it on overscroll.
			document.documentElement.style.backgroundColor =
				phase === "watch" ? "var(--color-surface-tile-1)" : "var(--color-canvas)";
		}

		private q<T extends HTMLElement>(sel: string): T {
			return this.querySelector<T>(sel)!;
		}

		// ============================================================
		// SETUP
		// ============================================================
		private bindSetup() {
			const presets = this.querySelectorAll<HTMLButtonElement>(".preset");
			presets.forEach((btn) => {
				btn.addEventListener("click", () => {
					const secs = Number(btn.dataset.seconds);
					this.setDurationInputs(secs);
					presets.forEach((b) => b.setAttribute("aria-pressed", String(b === btn)));
					this.syncDurationHint();
				});
			});

			this.querySelectorAll<HTMLInputElement>(".time-input[data-unit]").forEach((input) => {
				input.addEventListener("input", () => {
					presets.forEach((b) => b.setAttribute("aria-pressed", "false"));
					this.syncDurationHint();
				});
			});

			// Word pace is independent of the hold duration — its own listener.
			this.querySelectorAll<HTMLInputElement>(".time-input[data-pace-unit]").forEach((input) => {
				input.addEventListener("input", () => this.syncPaceHint());
			});

			this.q<HTMLButtonElement>('[data-action="start"]').addEventListener("click", () => this.startWatch());
		}

		// Total of the two pace inputs (min + sec), in seconds.
		private readPaceInputs(): number {
			const get = (unit: string) =>
				Number(this.q<HTMLInputElement>(`.time-input[data-pace-unit="${unit}"]`).value) || 0;
			return get("minutes") * 60 + get("seconds");
		}

		// Read the chosen word pace, clamped to [1s, 3min], in ms.
		private readWordPaceMs(): number {
			const secs = this.readPaceInputs();
			if (secs <= 0) return DEFAULT_WORD_INTERVAL_MS;
			const ms = secs * 1000;
			return Math.min(MAX_WORD_INTERVAL_MS, Math.max(MIN_WORD_INTERVAL_MS, ms));
		}

		// Begin is enabled only when both the hold duration and the word pace
		// are inside their allowed ranges.
		private durationValid(): boolean {
			const secs = this.readDurationInputs();
			return secs >= MIN_SECONDS && secs <= MAX_SECONDS;
		}

		private paceValid(): boolean {
			const ms = this.readPaceInputs() * 1000;
			return ms >= MIN_WORD_INTERVAL_MS && ms <= MAX_WORD_INTERVAL_MS;
		}

		private refreshStartButton() {
			this.q<HTMLButtonElement>('[data-action="start"]').disabled =
				!this.durationValid() || !this.paceValid();
		}

		private syncPaceHint() {
			const hint = this.q<HTMLElement>("[data-pace-hint]");
			if (!this.paceValid()) {
				hint.textContent = "Pace must be between 1 second and 3 minutes";
				hint.style.color = "var(--color-primary)";
			} else {
				hint.textContent = "";
			}
			this.refreshStartButton();
		}

		private readDurationInputs(): number {
			const get = (unit: string) =>
				Number(this.q<HTMLInputElement>(`.time-input[data-unit="${unit}"]`).value) || 0;
			return get("hours") * 3600 + get("minutes") * 60 + get("seconds");
		}

		private setDurationInputs(totalSec: number) {
			const h = Math.floor(totalSec / 3600);
			const m = Math.floor((totalSec % 3600) / 60);
			const s = totalSec % 60;
			this.q<HTMLInputElement>('.time-input[data-unit="hours"]').value = String(h);
			this.q<HTMLInputElement>('.time-input[data-unit="minutes"]').value = String(m);
			this.q<HTMLInputElement>('.time-input[data-unit="seconds"]').value = String(s);
		}

		private clampDuration(): number {
			let secs = this.readDurationInputs();
			secs = Math.min(MAX_SECONDS, Math.max(0, secs));
			return secs;
		}

		private syncDurationHint() {
			const secs = this.readDurationInputs();
			const hint = this.q<HTMLElement>("[data-duration-hint]");
			if (secs < MIN_SECONDS) {
				hint.textContent = `Hold must be at least ${MIN_SECONDS} seconds`;
				hint.style.color = "var(--color-primary)";
			} else if (secs > MAX_SECONDS) {
				hint.textContent = "Hold cannot exceed 12 hours";
				hint.style.color = "var(--color-primary)";
			} else {
				hint.textContent = "";
			}
			this.refreshStartButton();
		}

		// ============================================================
		// WATCH
		// ============================================================
		private bindWatch() {
			this.q<HTMLButtonElement>('[data-action="end-early"]').addEventListener("click", () => this.startRecall());
		}

		private startWatch() {
			this.durationSec = this.clampDuration();
			if (this.durationSec < MIN_SECONDS) return;
			this.wordIntervalMs = this.readWordPaceMs();

			this.shown = [];
			this.guesses = [];
			this.endsAt = performance.now() + this.durationSec * 1000;
			this.show("watch");

			const wordEl = this.q<HTMLElement>("[data-word]");
			const seenEl = this.q<HTMLElement>("[data-seen-count]");

			// One word per chosen interval → durationSec / interval words.
			// At least one word, even when the interval is longer than the hold.
			const targetWords = Math.max(1, Math.floor(this.durationSec / (this.wordIntervalMs / 1000)));

			const pushWord = () => {
				// Stop at the target so no phantom word sneaks in as the timer
				// expires — the recalled sequence must match what was shown.
				if (this.shown.length >= targetWords) {
					if (this.wordTimer !== null) window.clearInterval(this.wordTimer);
					this.wordTimer = null;
					return;
				}
				const next = randomWord(this.shown[this.shown.length - 1]);
				this.shown.push(next);
				wordEl.textContent = next;
				wordEl.animate(
					[{ opacity: 0, transform: "translateY(8px)" }, { opacity: 1, transform: "translateY(0)" }],
					{ duration: 280, easing: "ease-out" },
				);
				seenEl.textContent = `${this.shown.length} ${this.shown.length === 1 ? "word" : "words"}`;
			};

			pushWord(); // first word immediately
			this.wordTimer = window.setInterval(pushWord, this.wordIntervalMs);

			const progressEl = this.q<HTMLElement>("[data-progress]");
			const clockEl = this.q<HTMLElement>("[data-clock]");
			const tick = () => {
				const remainingMs = Math.max(0, this.endsAt - performance.now());
				const elapsed = this.durationSec * 1000 - remainingMs;
				progressEl.style.width = `${Math.min(100, (elapsed / (this.durationSec * 1000)) * 100)}%`;
				clockEl.textContent = this.formatClock(Math.ceil(remainingMs / 1000));
				if (remainingMs <= 0) this.startRecall();
			};
			tick();
			this.countdownTimer = window.setInterval(tick, 200);
		}

		private stopWatchTimers() {
			if (this.wordTimer !== null) window.clearInterval(this.wordTimer);
			if (this.countdownTimer !== null) window.clearInterval(this.countdownTimer);
			this.wordTimer = null;
			this.countdownTimer = null;
		}

		// ============================================================
		// RECALL — tap the shuffled inbox back in order
		// ============================================================
		private bindRecall() {
			// Pool tiles are created per-round in startRecall; taps are
			// handled via delegation so we bind the container once here.
			this.q<HTMLElement>("[data-pool]").addEventListener("click", (e) => {
				const tile = (e.target as HTMLElement).closest<HTMLButtonElement>(".pool-word");
				if (tile && !tile.disabled) this.pick(tile);
			});
		}

		private startRecall() {
			this.stopWatchTimers();
			// How long the timer actually held — full duration on a natural
			// timeout, or less if the player ended early. This is the attention span.
			const remainingMs = Math.max(0, this.endsAt - performance.now());
			this.attentionSec = Math.round(this.durationSec - remainingMs / 1000);
			this.guesses = [];
			this.recallIndex = 0;
			this.wrongPick = null;
			this.q<HTMLUListElement>("[data-recall-list]").innerHTML = "";
			this.renderPool();
			this.updateRecallProgress();
			this.show("recall");
			this.startRecallTimer();
		}

		// Recall window is double the chosen hold. Rebuilding the whole
		// sequence ends it early; otherwise the round ends when it expires
		// and the result reflects whatever was rebuilt so far.
		private startRecallTimer() {
			const recallMs = this.durationSec * 2 * 1000;
			this.recallStartedAt = performance.now();
			this.recallEndsAt = this.recallStartedAt + recallMs;
			const clockEl = this.q<HTMLElement>("[data-recall-clock]");
			const tick = () => {
				const leftMs = Math.max(0, this.recallEndsAt - performance.now());
				clockEl.textContent = `${this.formatClock(Math.ceil(leftMs / 1000))} left to recall`;
				if (leftMs <= 0) {
					this.stopRecallTimer();
					this.startResult(); // time's up — score what was rebuilt
				}
			};
			tick();
			this.recallTimer = window.setInterval(tick, 200);
		}

		private stopRecallTimer() {
			if (this.recallTimer !== null) window.clearInterval(this.recallTimer);
			this.recallTimer = null;
		}

		// Build the shuffled inbox: one tile per word shown (duplicates kept
		// so every position in the sequence has a matching tile to tap).
		private renderPool() {
			const pool = this.q<HTMLElement>("[data-pool]");
			pool.innerHTML = "";
			const tiles = this.shown.map((word, i) => ({ word, i }));
			for (let i = tiles.length - 1; i > 0; i--) {
				const j = Math.floor(Math.random() * (i + 1));
				[tiles[i], tiles[j]] = [tiles[j], tiles[i]];
			}
			tiles.forEach((t) => {
				const btn = document.createElement("button");
				btn.type = "button";
				btn.className = "pool-word";
				btn.dataset.word = t.word;
				btn.textContent = t.word;
				pool.appendChild(btn);
			});
		}

		private pick(tile: HTMLButtonElement) {
			const word = tile.dataset.word!;
			const target = this.shown[this.recallIndex];

			if (word === target) {
				// Correct — extend the focus span and take the tile out of the pool.
				this.guesses.push(word);
				this.recallIndex++;
				this.appendRebuilt(word);
				tile.remove();
				if (this.recallIndex >= this.shown.length) {
					this.startResult(); // whole sequence rebuilt
					return;
				}
				this.updateRecallProgress();
			} else {
				// Wrong — the chain breaks here, end the round.
				this.stopRecallTimer();
				tile.disabled = true;
				tile.classList.add("is-wrong");
				this.wrongPick = word;
				this.lockPool();
				window.setTimeout(() => this.startResult(), 520);
			}
		}

		private appendRebuilt(word: string) {
			const list = this.q<HTMLUListElement>("[data-recall-list]");
			const li = document.createElement("li");
			li.className = "chip chip-correct";
			li.textContent = word;
			list.appendChild(li);
		}

		private lockPool() {
			this.querySelectorAll<HTMLButtonElement>(".pool-word").forEach((b) => {
				if (!b.disabled) {
					b.disabled = true;
					b.classList.add("is-dim");
				}
			});
		}

		private updateRecallProgress() {
			this.q<HTMLElement>("[data-chosen-caption]").textContent =
				`Chosen sequence so far · ${this.guesses.length} of ${this.shown.length}`;
		}

		// ============================================================
		// RESULT — focus span = words tapped correctly before the chain broke
		// ============================================================
		private startResult() {
			this.stopRecallTimer();
			this.show("result");

			// How long the player took to rebuild the sequence this round.
			this.recallSec = Math.max(0, Math.round((performance.now() - this.recallStartedAt) / 1000));

			// Every committed guess was a correct, in-order tap (a wrong tap
			// ends the round before it is pushed), so the span is their count.
			const span = this.guesses.length;
			const total = this.shown.length;

			// Attention span = how long the timer actually held.
			this.q<HTMLElement>("[data-attention]").textContent = this.formatClock(this.attentionSec);

			// Focus = share of the sequence rebuilt correctly, in order.
			const focusPct = total === 0 ? 0 : Math.round((span / total) * 100);
			this.q<HTMLElement>("[data-focus]").textContent = `${focusPct}%`;
			this.q<HTMLElement>("[data-focus-detail]").textContent =
				`${span} of ${total} ${total === 1 ? "word" : "words"} in order`;

			const scoreLine = this.q<HTMLElement>("[data-score-line]");
			if (span === 0) {
				scoreLine.textContent = "The chain broke at the first word. Try a shorter hold and build up.";
			} else if (span === total) {
				scoreLine.textContent = `Flawless — you held attention for ${this.formatDuration(this.attentionSec)} and rebuilt all ${total} words.`;
			} else {
				scoreLine.textContent = `You held ${span} ${span === 1 ? "word" : "words"} in order before the chain broke at word ${span + 1} of ${total}.`;
			}

			this.updateBest(span);
			this.renderReveal();
		}

		private updateBest(span: number) {
			const line = this.q<HTMLElement>("[data-best-line]");
			// Rank by the same lexicographic rule as the server (submit_score):
			// more words wins; tie → longer attention; tie → faster recall.
			const isBetter =
				span > this.bestWords ||
				(this.bestWords > 0 && span === this.bestWords && (
					this.attentionSec > this.bestAttentionSec ||
					(this.attentionSec === this.bestAttentionSec && this.recallSec < this.bestRecallSec)
				));
			if (isBetter) {
				this.bestWords = span;
				this.bestAttentionSec = this.attentionSec;
				this.bestRecallSec = this.recallSec;

				// Push a real best to the world leaderboard. No-op when the
				// backend isn't configured or the player isn't signed in; the
				// server itself only overwrites when this score actually wins.
				// The server is the source of truth — no localStorage, so a best
				// can't leak across accounts sharing one browser.
				// Tell the header once the server has it, so an open leaderboard
				// panel / profile best refreshes instead of showing stale state.
				if (span > 0) {
					void submitBest({
						words: this.bestWords,
						attentionSec: this.bestAttentionSec,
						recallSec: this.bestRecallSec,
					}).then(() => {
						window.dispatchEvent(new CustomEvent("focus-attention:best-updated"));
					});
				}
			}
			line.textContent = this.bestWords === 0
				? ""
				: `Best Score: ${this.bestWords} ${this.bestWords === 1 ? "word" : "words"} · ${this.formatDuration(this.bestAttentionSec)} attention · recalled in ${this.formatDuration(this.bestRecallSec)}.`;
		}

		private renderReveal() {
			const list = this.q<HTMLElement>("[data-reveal-list]");
			list.innerHTML = "";
			const span = this.guesses.length;
			this.shown.forEach((word, i) => {
				// Arrow separator between words → reads as one sequence.
				if (i > 0) {
					const arrow = document.createElement("span");
					arrow.className = "reveal-arrow";
					arrow.textContent = "→";
					arrow.setAttribute("aria-hidden", "true");
					list.appendChild(arrow);
				}
				const chip = document.createElement("span");
				chip.textContent = word;
				if (i < span) {
					// Tapped correctly, in order.
					chip.className = "chip chip-correct";
				} else if (i === span && this.wrongPick) {
					// The break point — mark it, and note what was tapped instead.
					chip.className = "chip chip-wrong";
					chip.title = `You tapped "${this.wrongPick}"`;
				} else {
					// Never reached.
					chip.className = "chip chip-missed";
				}
				list.appendChild(chip);
			});
		}

		// ============================================================
		// RESULT actions
		// ============================================================
		private bindResult() {
			this.q<HTMLButtonElement>('[data-action="again"]').addEventListener("click", () => this.startWatch());
			this.q<HTMLButtonElement>('[data-action="change-time"]').addEventListener("click", () => this.show("setup"));
		}

		// ---- formatting helpers ----
		private formatClock(totalSec: number): string {
			const h = Math.floor(totalSec / 3600);
			const m = Math.floor((totalSec % 3600) / 60);
			const s = totalSec % 60;
			if (h > 0) return `${h}:${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
			return `${m}:${String(s).padStart(2, "0")}`;
		}

		private formatDuration(totalSec: number): string {
			const h = Math.floor(totalSec / 3600);
			const m = Math.floor((totalSec % 3600) / 60);
			const s = totalSec % 60;
			const parts: string[] = [];
			if (h) parts.push(`${h} hr`);
			if (m) parts.push(`${m} min`);
			if (s) parts.push(`${s} sec`);
			return parts.join(" ") || "0 sec";
		}
	}

	customElements.define("focus-game", FocusGame);
</script>
