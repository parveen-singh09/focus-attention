---

import { languages, LOCALES, FLAGS } from "../i18n/ui";
import { getLangFromUrl, switchLocalePath, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const h = t.header;

const localeLinks = LOCALES.map((code) => ({
	code,
	label: languages[code],
	flag: FLAGS[code],
	href: switchLocalePath(Astro.url, code),
	current: code === lang,
}));

const activeFlagEmoji = FLAGS[lang];

const headerI18n = {
	account: h.account,
	anonymous: h.anonymous,
	bestScore: h.bestScore,
	loginToTrack: h.loginToTrack,
	changePhoto: h.changePhoto,
	uploading: h.uploading,
	worldRanking: h.worldRanking,
	loading: h.loading,
	noScores: h.noScores,
	players: h.players,
	showMore: h.showMore,
	loginToCompete: h.loginToCompete,
	finishToClaim: h.finishToClaim,
	yourRank: h.yourRank,
	yourRankMetrics: h.yourRankMetrics,
	yourWorldRanking: h.yourWorldRanking,
	boardNotSetUp: h.boardNotSetUp,
	wordsUnit: h.wordsUnit,
};
---

<header class="sticky top-0 z-40 w-full border-b border-hairline bg-canvas/80 backdrop-blur-md" data-i18n={JSON.stringify(headerI18n)}>
	<div class="mx-auto flex h-14 max-w-300 items-center justify-between px-5">

		<div class="relative flex items-center gap-2" data-profile-wrap>
			<button type="button" class="icon-btn" data-action="profile" aria-label={h.account} aria-haspopup="menu" aria-expanded="false">
				<svg data-icon="user" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="8" r="4" />
					<path d="M4 21a8 8 0 0 1 16 0" />
				</svg>
				<img data-avatar hidden alt="" referrerpolicy="no-referrer" class="h-7 w-7 rounded-full object-cover" />
			</button>

			<span data-profile-rank hidden class="rank-badge" title={h.yourWorldRanking}></span>

			<div data-profile-menu hidden role="menu" class="dropdown left-0 right-auto min-w-48">
				<div class="px-3 py-2">
					<div data-name-display class="flex items-center gap-1.5">
						<p data-profile-name class="flex-1 min-w-0 text-caption text-ink-muted-80 truncate"></p>
						<button type="button" class="name-edit-btn" data-action="edit-name" aria-label={h.editName} title={h.editName}>
							<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M12 20h9" />
								<path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
							</svg>
						</button>
					</div>
					<form data-name-form hidden class="flex items-center gap-1.5">
						<input data-name-input type="text" maxlength="40" class="name-edit" aria-label={h.displayName} />
						<button type="submit" class="name-save" aria-label={h.save}>{h.save}</button>
					</form>
				</div>
				<div class="h-px w-full bg-hairline"></div>
				<div data-profile-best class="px-3 py-2"></div>
				<div class="h-px w-full bg-hairline"></div>
				<button type="button" class="menu-item" data-action="change-photo" role="menuitem">{h.changePhoto}</button>
				<input data-photo-input type="file" accept="image/*" hidden />
				<div class="h-px w-full bg-hairline"></div>
				<button type="button" class="menu-item menu-item--icon" data-action="signin" role="menuitem">
					<svg class="lb-g" viewBox="0 0 48 48" width="16" height="16" aria-hidden="true">
						<path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5Z" />
						<path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65Z" />
						<path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19Z" />
						<path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48Z" />
					</svg>
					<span>{h.login}</span>
				</button>
				<button type="button" class="menu-item" data-action="signout" role="menuitem" hidden>{h.logout}</button>
			</div>
		</div>

		<nav class="flex items-center gap-1" aria-label="Site actions">

			<button type="button" class="icon-btn" data-action="theme" aria-label={h.toggleTheme} aria-pressed="false" title={h.toggleTheme}>
				<svg data-icon="sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="12" cy="12" r="4" />
					<path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
				</svg>
				<svg data-icon="moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z" />
				</svg>
			</button>

			<div class="relative" data-lang-wrap>
				<button type="button" class="icon-btn" data-action="lang" aria-label={h.language} aria-haspopup="menu" aria-expanded="false" title={h.language}>
					<span class="lang-btn-icon" aria-hidden="true">{activeFlagEmoji}</span>

					<svg data-lang-globe viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style={activeFlagEmoji ? "display:none" : ""}>
						<circle cx="12" cy="12" r="9" />
						<path d="M3 12h18" /><path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18Z" />
					</svg>
				</button>

				<div data-lang-menu hidden role="menu" class="dropdown lang-dropdown right-0 left-auto w-52">
					{localeLinks.map((l) => (
						<a
							href={l.href}
							class:list={["lang-item", { "is-current": l.current }]}
							role="menuitem"
							hreflang={l.code}
							lang={l.code}
							aria-current={l.current ? "true" : undefined}
						>
							<span class="lang-flag" aria-hidden="true">{l.flag}</span>
							<span>{l.label}</span>
						</a>
					))}
				</div>
			</div>

			<div class="relative" data-board-wrap>
				<button type="button" class="icon-btn" data-action="leaderboard" aria-label={h.leaderboard} aria-haspopup="true" aria-expanded="false" title={h.leaderboard}>
					<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M8 21h8" /><path d="M12 17v4" />
						<path d="M7 4h10v5a5 5 0 0 1-10 0V4Z" />
						<path d="M17 5h3v2a3 3 0 0 1-3 3" /><path d="M7 5H4v2a3 3 0 0 0 3 3" />
					</svg>
				</button>

				<div data-board-panel hidden class="dropdown right-0 left-auto w-[min(92vw,360px)]">
					<div class="flex items-center justify-between px-3 pt-2 pb-1">
						<p class="text-caption text-ink uppercase tracking-[0.04em]">{h.worldRanking}</p>
						<span data-board-total class="text-fine text-ink-muted-48"></span>
					</div>
					<p class="px-3 pb-2 text-fine text-ink-muted-48">{h.rankedBy}</p>
					<div class="h-px w-full bg-hairline"></div>

					<ol data-board-list class="max-h-80 overflow-y-auto py-1"></ol>

					<div data-board-foot class="border-t border-hairline px-3 py-3"></div>
				</div>
			</div>
		</nav>
	</div>
</header>

<style>
	.icon-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border: none;
		background: transparent;
		color: var(--color-ink);
		border-radius: var(--radius-pill);
		cursor: pointer;
		transition: background-color 0.18s ease, transform 0.18s ease;
	}
	.icon-btn:hover { background-color: var(--color-canvas-parchment); }
	.icon-btn:active { transform: scale(0.92); }
	.icon-btn:focus-visible { outline: 2px solid var(--color-primary-focus); outline-offset: 2px; }

	.rank-badge {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-text);
		font-size: 19px;
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		color: var(--color-ink-muted-48);
		border-radius: var(--radius-pill);
		padding: 2px 8px;
		line-height: 1.4;
		white-space: nowrap;
	}
	.rank-badge[hidden] { display: none; }

	.rank-badge--1 { color: #e5484d; }
	.rank-badge--2 { color: #30a46c; }
	.rank-badge--3 { color: #3e63dd; }
	.rank-badge--4 { color: #e93d82; }
	.rank-badge--5 { color: #eab308; }

	[data-icon="sun"] { display: none; }
	:global(html[data-theme="dark"]) [data-icon="sun"] { display: block; }
	:global(html[data-theme="dark"]) [data-icon="moon"] { display: none; }

	.dropdown {
		position: absolute;
		top: calc(100% + 8px);
		background-color: var(--color-canvas);
		border: 1px solid var(--color-hairline);
		border-radius: var(--radius-md);
		box-shadow: rgba(0, 0, 0, 0.16) 0 8px 30px 0;
		z-index: 50;
		overflow: hidden;
	}

	.lang-dropdown {
		overflow-y: auto;
		max-height: min(70vh, 360px);
		scrollbar-width: thin;
		scrollbar-color: transparent transparent;
	}
	.lang-dropdown:hover {
		scrollbar-color: var(--color-hairline) transparent;
	}
	.lang-dropdown::-webkit-scrollbar {
		width: 3px;
	}
	.lang-dropdown::-webkit-scrollbar-track {
		background: transparent;
	}
	.lang-dropdown::-webkit-scrollbar-thumb {
		background: transparent;
		border-radius: 99px;
	}
	.lang-dropdown:hover::-webkit-scrollbar-thumb {
		background: var(--color-hairline);
	}

	.menu-item {
		display: block;
		width: 100%;
		text-align: left;
		padding: 10px 12px;
		font-family: var(--font-text);
		font-size: 15px;
		color: var(--color-ink);
		background: transparent;
		border: none;
		cursor: pointer;
	}
	.menu-item:hover { background-color: var(--color-canvas-parchment); }
	.menu-item:focus-visible { outline: 2px solid var(--color-primary-focus); outline-offset: -2px; }
	.menu-item[hidden] { display: none; }
	.menu-item:disabled { opacity: 0.4; cursor: not-allowed; }
	.menu-item:disabled:hover { background-color: transparent; }
	.menu-item--icon { display: flex; align-items: center; gap: 0.5rem; }
	.menu-item--icon[hidden] { display: none; }
	.menu-item--icon .lb-g { flex: none; }

	.lang-item {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 9px 12px;
		font-family: var(--font-text);
		font-size: 15px;
		color: var(--color-ink);
		text-decoration: none;
	}
	.lang-item:hover { background-color: var(--color-canvas-parchment); }
	.lang-item:focus-visible { outline: 2px solid var(--color-primary-focus); outline-offset: -2px; }
	.lang-item.is-current { color: var(--color-primary); font-weight: 600; }

	.lang-flag {
		font-size: 18px;
		line-height: 1;
		flex: none;
	}
	.lang-btn-icon {
		font-size: 20px;
		line-height: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.name-edit-btn {
		flex: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 24px;
		height: 24px;
		border: none;
		background: transparent;
		color: var(--color-ink-muted-48);
		border-radius: var(--radius-pill);
		cursor: pointer;
		transition: background-color 0.18s ease, color 0.18s ease;
	}
	.name-edit-btn:hover { background-color: var(--color-canvas-parchment); color: var(--color-ink); }
	.name-edit-btn:focus-visible { outline: 2px solid var(--color-primary-focus); outline-offset: 1px; }
	.name-edit-btn:disabled { opacity: 0.4; cursor: not-allowed; }
	.name-edit-btn:disabled:hover { background-color: transparent; color: var(--color-ink-muted-48); }
	.name-edit {
		flex: 1 1 auto;
		min-width: 0;
		font-family: var(--font-text);
		font-size: 14px;
		color: var(--color-ink);
		background: var(--color-canvas);
		border: none;
		border-radius: var(--radius-md);
		padding: 5px 8px;
	}
	.name-edit:focus-visible { outline: none; }
	.name-save {
		flex: none;
		font-family: var(--font-text);
		font-size: 13px;
		color: var(--color-primary);
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 4px 6px;
	}
	.name-save:hover { text-decoration: underline; }
	[data-name-form][hidden] { display: none; }

	:global(.lb-row) {
		display: grid;
		grid-template-columns: 1.8rem 1.5rem 1fr auto;
		align-items: center;
		gap: 0.5rem;
		padding: 7px 12px;
		font-family: var(--font-text);
		font-size: 14px;
		color: var(--color-ink);
	}
	:global(.lb-row .lb-rank) { color: var(--color-ink-muted-48); font-variant-numeric: tabular-nums; }
	:global(.lb-row .lb-rank--1) { color: #e5484d; font-weight: 700; }
	:global(.lb-row .lb-rank--2) { color: #30a46c; font-weight: 700; }
	:global(.lb-row .lb-rank--3) { color: #3e63dd; font-weight: 700; }
	:global(.lb-row .lb-rank--4) { color: #e93d82; font-weight: 700; }
	:global(.lb-row .lb-rank--5) { color: #eab308; font-weight: 700; }
	:global(.lb-row .lb-dp) {
		width: 24px; height: 24px; border-radius: var(--radius-pill);
		object-fit: cover; background-color: var(--color-canvas-parchment);
	}
	:global(.lb-row .lb-dp-fallback) {
		width: 24px; height: 24px; border-radius: var(--radius-pill);
		display: inline-flex; align-items: center; justify-content: center;
		background-color: var(--color-canvas-parchment);
		color: var(--color-ink-muted-48); font-size: 11px; font-weight: 600; text-transform: uppercase;
	}
	:global(.lb-row .lb-name) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
	:global(.lb-row .lb-metrics) { color: var(--color-ink-muted-48); font-variant-numeric: tabular-nums; font-size: 12px; }
	:global(.lb-row.is-me) { background-color: color-mix(in srgb, var(--color-primary) 12%, transparent); }
	:global(.lb-row.is-me .lb-name) { color: var(--color-primary); font-weight: 600; }

	:global(.lb-empty) { padding: 16px 12px; font-size: 14px; color: var(--color-ink-muted-48); text-align: center; }

	:global(.lb-more) { padding: 6px 12px 8px; }
	:global(.lb-more-btn) {
		display: block;
		width: 100%;
		font-family: var(--font-text);
		font-size: 13px;
		font-weight: 500;
		color: var(--color-primary);
		background: transparent;
		border: 1px solid var(--color-hairline);
		border-radius: var(--radius-pill);
		padding: 8px 12px;
		cursor: pointer;
		transition: background-color 0.18s ease;
	}
	:global(.lb-more-btn:hover) { background-color: var(--color-canvas-parchment); }
	:global(.lb-more-btn:disabled) { opacity: 0.6; cursor: default; }
	:global(.lb-more-btn:focus-visible) { outline: 2px solid var(--color-primary-focus); outline-offset: 2px; }

	:global(.lb-btn) {
		display: inline-flex; align-items: center; justify-content: center; gap: 0.625rem;
		width: 100%;
		background-color: transparent;
		color: var(--color-ink);
		font-family: var(--font-text); font-size: 15px; font-weight: 500;
		border: 1px solid var(--color-hairline); border-radius: var(--radius-pill);
		padding: 11px 16px; cursor: pointer;
		transition: background-color 0.18s ease, transform 0.18s ease;
	}
	:global(.lb-btn:hover) { background-color: var(--color-canvas-parchment); }
	:global(.lb-btn:active) { transform: scale(0.97); }
	:global(.lb-btn .lb-g) { flex: none; }
	:global(.lb-foot-note) { font-size: 13px; color: var(--color-ink-muted-48); text-align: center; }
</style>

<script>
	import {
		isConfigured,
		getSession,
		onAuthChange,
		signInWithGoogle,
		signOut,
		displayNameFromSession,
		updateProfile,
		uploadAvatar,
		fetchMyProfile,
		submitBest,
		fetchMyBest,
		fetchTop,
		fetchMyRank,
		type LeaderboardRow,
	} from "../lib/leaderboard";
	import type { Session } from "@supabase/supabase-js";

	const root = document.documentElement;
	const $ = <T extends HTMLElement>(sel: string) => document.querySelector<T>(sel);

	interface HeaderStrings {
		account: string;
		anonymous: string;
		bestScore: string;
		loginToTrack: string;
		changePhoto: string;
		uploading: string;
		worldRanking: string;
		loading: string;
		noScores: string;
		players: string; 
		showMore: string;
		loginToCompete: string;
		finishToClaim: string;
		yourRank: string; 
		yourRankMetrics: string; 
		yourWorldRanking: string;
		boardNotSetUp: string;
		wordsUnit: string;
	}
	const STR: HeaderStrings = {
		account: "Account",
		anonymous: "Anonymous",
		bestScore: "Best score",
		loginToTrack: "Log in to track your best.",
		changePhoto: "Change photo",
		uploading: "Uploading…",
		worldRanking: "World ranking",
		loading: "Loading…",
		noScores: "No scores yet. Be the first.",
		players: "{n} players",
		showMore: "Show more",
		loginToCompete: "Log in to compete",
		finishToClaim: "Finish a round to claim your spot.",
		yourRank: "You're #{rank} of {total}.",
		yourRankMetrics: "You're #{rank} of {total} · {metrics}",
		yourWorldRanking: "Your world ranking",
		boardNotSetUp: "Leaderboard isn't set up yet.",
		wordsUnit: "w",
		...(() => {
			try {
				const raw = $<HTMLElement>("header[data-i18n]")?.dataset.i18n;
				return raw ? (JSON.parse(raw) as Partial<HeaderStrings>) : {};
			} catch {
				return {};
			}
		})(),
	};
	const fill = (tpl: string, vars: Record<string, string | number>) =>
		tpl.replace(/\{(\w+)\}/g, (_, k) => (k in vars ? String(vars[k]) : `{${k}}`));

	const langWrap = $<HTMLElement>("[data-lang-wrap]");
	const langBtn = $<HTMLButtonElement>('[data-action="lang"]');
	const langMenu = $<HTMLElement>("[data-lang-menu]");
	function closeLangMenu() {
		if (langMenu) langMenu.hidden = true;
		langBtn?.setAttribute("aria-expanded", "false");
	}
	langBtn?.addEventListener("click", () => {
		if (!langMenu) return;
		const open = langMenu.hidden;
		langMenu.hidden = !open;
		langBtn.setAttribute("aria-expanded", String(open));
	});

	const THEME_KEY = "focus-attention:theme";
	const themeBtn = $<HTMLButtonElement>('[data-action="theme"]');
	const syncPressed = () =>
		themeBtn?.setAttribute("aria-pressed", String(root.getAttribute("data-theme") === "dark"));
	syncPressed();
	themeBtn?.addEventListener("click", () => {
		const dark = root.getAttribute("data-theme") === "dark";
		dark ? root.removeAttribute("data-theme") : root.setAttribute("data-theme", "dark");
		try { localStorage.setItem(THEME_KEY, dark ? "light" : "dark"); } catch {}
		syncPressed();
	});

	function fmt(totalSec: number): string {
		const h = Math.floor(totalSec / 3600);
		const m = Math.floor((totalSec % 3600) / 60);
		const s = totalSec % 60;
		if (h > 0) return `${h}h ${m}m`;
		if (m > 0) return `${m}m ${s}s`;
		return `${s}s`;
	}
	function metrics(r: LeaderboardRow): string {
		return `${r.words}w · ${fmt(r.attentionSec)} · ${fmt(r.recallSec)}`;
	}

	let session: Session | null = null;

	const profileWrap = $<HTMLElement>("[data-profile-wrap]");
	const profileBtn = $<HTMLButtonElement>('[data-action="profile"]');
	const profileMenu = $<HTMLElement>("[data-profile-menu]");
	const profileName = $<HTMLElement>("[data-profile-name]");
	const profileBest = $<HTMLElement>("[data-profile-best]");
	const profileRank = $<HTMLElement>("[data-profile-rank]");
	const avatar = $<HTMLImageElement>("[data-avatar]");
	const userIcon = $<SVGElement & HTMLElement>('[data-icon="user"]');
	const signInBtn = $<HTMLButtonElement>('[data-action="signin"]');
	const signOutBtn = $<HTMLButtonElement>('[data-action="signout"]');
	const editNameBtn = $<HTMLButtonElement>('[data-action="edit-name"]');
	const changePhotoBtn = $<HTMLButtonElement>('[data-action="change-photo"]');
	const nameForm = $<HTMLFormElement>("[data-name-form]");
	const nameDisplay = $<HTMLElement>("[data-name-display]");
	const nameInput = $<HTMLInputElement>("[data-name-input]");
	const photoInput = $<HTMLInputElement>("[data-photo-input]");

	async function renderProfileBest() {
		if (!profileBest) return;

		if (!session) {
			profileBest.innerHTML = `<p class="text-caption text-ink-muted-80">${STR.bestScore}</p><p class="text-fine text-ink-muted-48 mt-0.5">${STR.loginToTrack}</p>`;
			return;
		}

		const best = await fetchMyBest();

		if (!session) return;

		const words = best?.words ?? 0;
		const attentionSec = best?.attentionSec ?? 0;
		const recallSec = best?.recallSec ?? 0;
		profileBest.innerHTML =
			`<p class="text-caption text-ink-muted-80">${STR.bestScore}</p>` +
			`<p class="text-fine text-ink-muted-48 mt-0.5">${words}w · ${fmt(attentionSec)} · ${fmt(recallSec)}</p>`;
	}

	async function renderRank() {
		if (!profileRank) return;
		if (!session) {
			profileRank.hidden = true;
			profileRank.textContent = "";
			return;
		}
		const uid = session.user.id;
		const mine = await fetchMyRank(uid);

		if (!session || session.user.id !== uid) return;

		profileRank.classList.remove(
			"rank-badge--1", "rank-badge--2", "rank-badge--3", "rank-badge--4", "rank-badge--5",
		);
		if (mine) {
			profileRank.textContent = `#${mine.row.rank}`;
			profileRank.title = fill(STR.yourRank, { rank: mine.row.rank, total: mine.total });

			if (mine.row.rank <= 5) profileRank.classList.add(`rank-badge--${mine.row.rank}`);
			profileRank.hidden = false;
		} else {
			profileRank.hidden = true;
			profileRank.textContent = "";
		}
	}

	function renderAuth() {
		const name = displayNameFromSession(session);

		if (editNameBtn) editNameBtn.disabled = !session;
		if (changePhotoBtn) changePhotoBtn.disabled = !session;
		if (session) {
			profileBtn?.setAttribute("aria-label", name);
			if (profileName) profileName.textContent = name;
			if (signInBtn) signInBtn.hidden = true;
			if (signOutBtn) signOutBtn.hidden = false;
			const pic = (session.user.user_metadata as Record<string, unknown>)?.avatar_url as string | undefined;
			if (pic && avatar) {
				avatar.src = pic;
				avatar.hidden = false;
				if (userIcon) userIcon.style.display = "none";
			}
		} else {
			profileBtn?.setAttribute("aria-label", STR.account);
			if (profileName) profileName.textContent = STR.anonymous;
			if (signInBtn) signInBtn.hidden = false;
			if (signOutBtn) signOutBtn.hidden = true;
			if (avatar) avatar.hidden = true;
			if (userIcon) userIcon.style.display = "";

			if (nameForm) nameForm.hidden = true;
			if (nameDisplay) nameDisplay.hidden = false;
		}
	}

	function closeProfileMenu() {
		if (profileMenu) profileMenu.hidden = true;
		profileBtn?.setAttribute("aria-expanded", "false");
	}

	async function applyStoredProfile() {
		if (!session) return;
		const uid = session.user.id;
		const prof = await fetchMyProfile();

		if (!prof || !session || session.user.id !== uid) return;
		if (prof.displayName) {
			if (profileName) profileName.textContent = prof.displayName;
			profileBtn?.setAttribute("aria-label", prof.displayName);
		}
		if (prof.avatarUrl && avatar) {
			avatar.src = prof.avatarUrl;
			avatar.hidden = false;
			if (userIcon) userIcon.style.display = "none";
		}
	}

	profileBtn?.addEventListener("click", () => {

		const open = profileMenu && profileMenu.hidden;
		if (open) renderProfileBest();
		if (profileMenu) profileMenu.hidden = !open;
		profileBtn.setAttribute("aria-expanded", String(!!open));
	});

	signInBtn?.addEventListener("click", async () => {
		if (!isConfigured) return; 
		await signInWithGoogle(); 
	});

	$<HTMLButtonElement>('[data-action="signout"]')?.addEventListener("click", async () => {
		await signOut();
		closeProfileMenu();
	});

	function openNameEditor() {
		if (!session || !nameForm || !nameInput || !nameDisplay) return;

		nameInput.value = profileName?.textContent?.trim() || displayNameFromSession(session);
		nameDisplay.hidden = true;
		nameForm.hidden = false;
		nameInput.focus();
		nameInput.select();
	}
	function closeNameEditor() {
		if (nameForm) nameForm.hidden = true;
		if (nameDisplay) nameDisplay.hidden = false;
	}

	editNameBtn?.addEventListener("click", openNameEditor);

	nameInput?.addEventListener("keydown", (e) => {
		if (e.key === "Escape") { e.stopPropagation(); closeNameEditor(); }
	});

	nameForm?.addEventListener("submit", async (e) => {
		e.preventDefault();
		if (!session || !nameInput) return;
		const next = nameInput.value.trim();
		if (!next) return;
		const ok = await updateProfile({ displayName: next });
		if (ok) {
			if (profileName) profileName.textContent = next;
			profileBtn?.setAttribute("aria-label", next);
			closeNameEditor();

			if (boardPanel && !boardPanel.hidden) loadBoard();
		}
	});

	changePhotoBtn?.addEventListener("click", () => {
		if (!session) return;
		photoInput?.click();
	});

	photoInput?.addEventListener("change", async () => {
		const file = photoInput.files?.[0];
		if (!file || !session) return;
		const prevLabel = changePhotoBtn?.textContent;
		if (changePhotoBtn) { changePhotoBtn.disabled = true; changePhotoBtn.textContent = STR.uploading; }

		const url = await uploadAvatar(file);
		if (url) {
			await updateProfile({ avatarUrl: url });
			if (avatar) { avatar.src = url; avatar.hidden = false; }
			if (userIcon) userIcon.style.display = "none";
			if (boardPanel && !boardPanel.hidden) loadBoard();
		}

		if (changePhotoBtn) { changePhotoBtn.disabled = false; changePhotoBtn.textContent = prevLabel ?? STR.changePhoto; }
		photoInput.value = ""; 
	});

	const boardBtn = $<HTMLButtonElement>('[data-action="leaderboard"]');
	const boardPanel = $<HTMLElement>("[data-board-panel]");
	const boardList = $<HTMLOListElement>("[data-board-list]");
	const boardTotal = $<HTMLElement>("[data-board-total]");
	const boardFoot = $<HTMLElement>("[data-board-foot]");

	const BOARD_PAGE = 15;
	let boardLoaded = 0; 
	let boardMoreLi: HTMLLIElement | null = null; 

	function initials(name: string): string {
		const parts = name.trim().split(/\s+/).filter(Boolean);
		if (parts.length === 0) return "?";
		if (parts.length === 1) return parts[0].slice(0, 2);
		return (parts[0][0] + parts[parts.length - 1][0]);
	}

	function rowEl(r: LeaderboardRow, isMe: boolean): HTMLLIElement {
		const li = document.createElement("li");
		li.className = "lb-row" + (isMe ? " is-me" : "");

		const rank = document.createElement("span");
		rank.className = "lb-rank" + (r.rank <= 5 ? ` lb-rank--${r.rank}` : "");
		rank.textContent = `#${r.rank}`;

		let dp: HTMLElement;
		if (r.avatarUrl) {
			const img = document.createElement("img");
			img.className = "lb-dp";
			img.src = r.avatarUrl;
			img.alt = "";
			img.loading = "lazy";
			img.referrerPolicy = "no-referrer"; 
			dp = img;
		} else {
			dp = document.createElement("span");
			dp.className = "lb-dp-fallback";
			dp.textContent = initials(r.displayName);
		}

		const name = document.createElement("span");
		name.className = "lb-name";
		name.textContent = r.displayName;

		const met = document.createElement("span");
		met.className = "lb-metrics";
		met.textContent = metrics(r);

		li.append(rank, dp, name, met);
		return li;
	}

	function setFootSignIn() {
		if (!boardFoot) return;
		boardFoot.innerHTML = "";
		const btn = document.createElement("button");
		btn.className = "lb-btn";
		btn.type = "button";
		btn.innerHTML =
			`<svg class="lb-g" viewBox="0 0 48 48" width="18" height="18" aria-hidden="true">` +
				`<path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5Z"/>` +
				`<path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65Z"/>` +
				`<path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19Z"/>` +
				`<path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48Z"/>` +
			`</svg>` +
			`<span>${STR.loginToCompete}</span>`;
		btn.addEventListener("click", () => signInWithGoogle());
		boardFoot.appendChild(btn);
	}

	function setFootMyRank(text: string) {
		if (!boardFoot) return;
		boardFoot.innerHTML = `<p class="lb-foot-note">${text}</p>`;
	}

	async function loadBoard() {
		if (!boardList) return;
		boardList.innerHTML = `<li class="lb-empty">${STR.loading}</li>`;
		if (boardFoot) boardFoot.innerHTML = "";

		boardLoaded = 0;
		boardMoreLi = null;

		const top = await fetchTop(BOARD_PAGE, 0);
		boardList.innerHTML = "";

		if (top.length === 0) {
			boardList.innerHTML = `<li class="lb-empty">${STR.noScores}</li>`;
		} else {
			const myId = session?.user.id;
			top.forEach((r) => boardList.appendChild(rowEl(r, r.userId === myId)));
			boardLoaded = top.length;

			if (top.length === BOARD_PAGE) addShowMore();
		}

		if (boardTotal) boardTotal.textContent = top.length ? "" : "";

		if (!session) {
			setFootSignIn();
			return;
		}
		const mine = await fetchMyRank(session.user.id);
		if (boardTotal) boardTotal.textContent = mine ? fill(STR.players, { n: mine.total }) : "";
		if (!mine) {
			setFootMyRank(STR.finishToClaim);
			return;
		}
		const inTop = top.some((r) => r.userId === session!.user.id);
		setFootMyRank(inTop
			? fill(STR.yourRank, { rank: mine.row.rank, total: mine.total })
			: fill(STR.yourRankMetrics, { rank: mine.row.rank, total: mine.total, metrics: metrics(mine.row) }));
	}

	async function loadMore() {
		if (!boardList) return;
		boardMoreLi?.remove();
		boardMoreLi = null;
		const page = await fetchTop(BOARD_PAGE, boardLoaded);
		const myId = session?.user.id;
		page.forEach((r) => boardList.appendChild(rowEl(r, r.userId === myId)));
		boardLoaded += page.length;

		if (page.length === BOARD_PAGE) addShowMore();
	}

	function addShowMore() {
		if (!boardList) return;
		const li = document.createElement("li");
		li.className = "lb-more";
		const btn = document.createElement("button");
		btn.type = "button";
		btn.className = "lb-more-btn";
		btn.textContent = STR.showMore;
		btn.addEventListener("click", () => {
			btn.disabled = true;
			btn.textContent = STR.loading;
			loadMore();
		});
		li.appendChild(btn);
		boardList.appendChild(li);
		boardMoreLi = li;
	}

	function openBoard() {
		if (!boardPanel) return;
		if (!isConfigured) {
			boardPanel.hidden = false;
			boardBtn?.setAttribute("aria-expanded", "true");
			if (boardList) boardList.innerHTML = `<li class="lb-empty">${STR.boardNotSetUp}</li>`;
			if (boardFoot) boardFoot.innerHTML = "";
			if (boardTotal) boardTotal.textContent = "";
			return;
		}
		boardPanel.hidden = false;
		boardBtn?.setAttribute("aria-expanded", "true");
		loadBoard();
	}
	function closeBoard() {
		if (boardPanel) boardPanel.hidden = true;
		boardBtn?.setAttribute("aria-expanded", "false");
	}

	boardBtn?.addEventListener("click", () => {
		const open = boardPanel && boardPanel.hidden;
		open ? openBoard() : closeBoard();
	});

	document.addEventListener("click", (e) => {
		const t = e.target as Node;
		if (boardPanel && !boardPanel.hidden && !$<HTMLElement>("[data-board-wrap]")?.contains(t)) closeBoard();
		if (profileMenu && !profileMenu.hidden && !profileWrap?.contains(t)) closeProfileMenu();
		if (langMenu && !langMenu.hidden && !langWrap?.contains(t)) closeLangMenu();
	});
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape") { closeBoard(); closeProfileMenu(); closeLangMenu(); }
	});

	window.addEventListener("focus-attention:best-updated", () => {
		renderProfileBest();
		renderRank(); 
		if (boardPanel && !boardPanel.hidden) loadBoard();
	});

	renderAuth(); 

	let baselinedFor: string | null = null;
	async function ensureBaseline(s: Session | null) {
		if (!s || s.user.id === baselinedFor) return;
		baselinedFor = s.user.id;
		await submitBest({ words: 0, attentionSec: 0, recallSec: 0 });
		renderRank(); 
		if (boardPanel && !boardPanel.hidden) loadBoard();
	}

	let lastUserId: string | null | undefined = undefined;
	function applySession(s: Session | null) {
		const changed = (s?.user.id ?? null) !== (lastUserId ?? null);
		lastUserId = s?.user.id ?? null;
		session = s;
		renderAuth();
		void applyStoredProfile(); 
		void renderRank(); 
		void ensureBaseline(s);

		if (boardPanel && !boardPanel.hidden) loadBoard();

		if (changed) window.dispatchEvent(new CustomEvent("focus-attention:auth-changed"));
	}

	if (isConfigured) {
		getSession().then(applySession);
		onAuthChange(applySession);
	}
</script>
