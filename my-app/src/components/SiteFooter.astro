---
// SiteFooter — global footer with site navigation. Lives in the Layout so it
// renders on every page: each page then links to every other page, which is
// strong internal linking for SEO and makes the legal / info pages reachable
// from the home page. Static MPA — these are plain <a> hrefs to real routes.
//
// i18n: link labels + the tagline/rights line are localized. Only the Home
// link is locale-aware (→ /<lang>); about/contact/privacy/terms exist ONLY as
// English pages at the root, so they always link to those root paths (no
// /<lang>/about route exists to point at).
import { getLangFromUrl, translatePath, useTranslations, fill } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const f = t.footer;
const year = new Date().getFullYear();

const links = [
	{ href: translatePath("/", lang), label: f.home },
	{ href: "/about", label: f.about },
	{ href: "/contact", label: f.contact },
	{ href: "/privacy", label: f.privacy },
	{ href: "/terms", label: f.terms },
];
---

<footer data-site-footer class="bg-canvas-parchment text-ink-muted-80 border-t border-hairline">
	<div class="mx-auto max-w-5xl px-6 py-14">
		<nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3" aria-label="Footer">
			{links.map((l) => (
				<a href={l.href} class="footer-link">{l.label}</a>
			))}
		</nav>
		<p class="text-caption text-center mt-8">
			{f.tagline}
		</p>
		<p class="text-fine text-ink-muted-48 text-center mt-2">
			{fill(f.rights, { year })}
		</p>
	</div>
</footer>

<style>
	.footer-link {
		font-family: var(--font-text);
		font-size: 15px;
		letter-spacing: -0.224px;
		color: var(--color-ink-muted-80);
		text-decoration: none;
		transition: color 0.18s ease;
	}
	.footer-link:hover { color: var(--color-primary); }
	.footer-link:focus-visible {
		outline: 2px solid var(--color-primary-focus);
		outline-offset: 3px;
		border-radius: var(--radius-xs);
	}
</style>
