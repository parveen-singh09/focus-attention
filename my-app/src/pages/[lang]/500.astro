---
// Per-locale 500 at /<lang>/500. Like the localized 404, generated for
// completeness; static hosts serve the root /500.html. English 500 lives at
// the root (src/pages/500.astro).
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import { LOCALES, defaultLang, isLang } from "../../i18n/ui";
import { useTranslations, translatePath } from "../../i18n/utils";

export const getStaticPaths = (() => {
	return LOCALES.filter((l) => l !== defaultLang).map((lang) => ({
		params: { lang },
	}));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
if (!isLang(lang)) throw new Error(`Unknown locale: ${lang}`);
const t = useTranslations(lang);
const e = t.errors;
const home = translatePath("/", lang);
---

<Layout
	title={t.meta.errorTitle}
	description={t.meta.errorDescription}
	noindex={true}
>
	<main class="min-h-[78vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-4 uppercase tracking-[0.04em]">{e.errorEyebrow}</p>
		<h1 class="text-hero text-ink max-w-[16ch]">{e.errorHeading}</h1>
		<p class="text-lead text-ink-muted-80 mt-5 max-w-[44ch]">
			{e.errorLead}
		</p>
		<div class="mt-12 flex items-center gap-3">
			<button type="button" data-action="retry" class="btn-primary">{e.tryAgain}</button>
			<a href={home} class="btn-ghost">{e.backToGame}</a>
		</div>
	</main>

	<script>
		// Reload the route that errored, rather than always sending people home.
		document
			.querySelector('[data-action="retry"]')
			?.addEventListener("click", () => location.reload());
	</script>
</Layout>
