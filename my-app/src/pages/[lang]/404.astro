---
// Per-locale 404 at /<lang>/404. Static hosts only auto-serve the root
// /404.html for unknown routes, so these are generated for completeness and
// correct rendering when linked directly — not auto-served. English 404 lives
// at the root (src/pages/404.astro).
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import { LOCALES, defaultLang, isLang } from "../../i18n/ui";
import { useTranslations, translatePath } from "../../i18n/utils";

export const getStaticPaths = (() => {
	return LOCALES.filter((l) => l !== defaultLang).map((lang) => ({
		params: { lang },
	}));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
if (!isLang(lang)) throw new Error(`Unknown locale: ${lang}`);
const t = useTranslations(lang);
const e = t.errors;
const home = translatePath("/", lang);
---

<Layout
	title={t.meta.notFoundTitle}
	description={t.meta.notFoundDescription}
	noindex={true}
>
	<main class="min-h-[78vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-4 uppercase tracking-[0.04em]">{e.notFoundEyebrow}</p>
		<h1 class="text-hero text-ink max-w-[16ch]">{e.notFoundHeading}</h1>
		<p class="text-lead text-ink-muted-80 mt-5 max-w-[44ch]">
			{e.notFoundLead}
		</p>
		<div class="mt-12">
			<a href={home} class="btn-primary">{e.backToGame}</a>
		</div>
	</main>
</Layout>
