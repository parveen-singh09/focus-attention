---
// Localized landing pages at /<lang>/ for every non-default locale. English
// stays at the root (src/pages/index.astro), so it is excluded here. All
// markup is shared via HomePage.astro.
import type { GetStaticPaths } from "astro";
import { LOCALES, defaultLang, isLang } from "../../i18n/ui";
import HomePage from "../../components/HomePage.astro";

export const getStaticPaths = (() => {
	return LOCALES.filter((l) => l !== defaultLang).map((lang) => ({
		params: { lang },
	}));
}) satisfies GetStaticPaths;

const { lang } = Astro.params;
// Narrow the route param to a known locale (getStaticPaths guarantees it).
if (!isLang(lang)) throw new Error(`Unknown locale: ${lang}`);
---

<HomePage lang={lang} />
