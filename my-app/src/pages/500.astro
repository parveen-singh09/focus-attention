---
import Layout from "../layouts/Layout.astro";
import { useTranslations } from "../i18n/utils";

const t = useTranslations("en");
const e = t.errors;
---

<Layout
	title={t.meta.errorTitle}
	description={t.meta.errorDescription}
	noindex={true}
>
	<main class="min-h-[78vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-4 uppercase tracking-[0.04em]">{e.errorEyebrow}</p>
		<h1 class="text-hero text-ink max-w-[16ch]">{e.errorHeading}</h1>
		<p class="text-lead text-ink-muted-80 mt-5 max-w-[44ch]">
			{e.errorLead}
		</p>
		<div class="mt-12 flex items-center gap-3">
			<button type="button" data-action="retry" class="btn-primary">{e.tryAgain}</button>
			<a href="/" class="btn-ghost">{e.backToGame}</a>
		</div>
	</main>
</Layout>

<script>

	document
		.querySelector('[data-action="retry"]')
		?.addEventListener("click", () => location.reload());
</script>
