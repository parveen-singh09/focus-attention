---
import Layout from "../layouts/Layout.astro";
import { useTranslations } from "../i18n/utils";

// Static build → this compiles to 404.html, which static hosts serve for any
// unknown route. noindex so the error page never lands in search results.
const t = useTranslations("en");
const e = t.errors;
---

<Layout
	title={t.meta.notFoundTitle}
	description={t.meta.notFoundDescription}
	noindex={true}
>
	<main class="min-h-[78vh] flex flex-col items-center justify-center px-6 py-(--spacing-section) text-center">
		<p class="text-caption text-ink-muted-48 mb-4 uppercase tracking-[0.04em]">{e.notFoundEyebrow}</p>
		<h1 class="text-hero text-ink max-w-[16ch]">{e.notFoundHeading}</h1>
		<p class="text-lead text-ink-muted-80 mt-5 max-w-[44ch]">
			{e.notFoundLead}
		</p>
		<div class="mt-12">
			<a href="/" class="btn-primary">{e.backToGame}</a>
		</div>
	</main>
</Layout>
