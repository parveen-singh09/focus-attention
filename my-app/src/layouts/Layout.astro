---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import type { Lang } from "../i18n/ui";
import { HTML_LANG, defaultLang, dirFor } from "../i18n/ui";
import { getLangFromUrl, stripLangPrefix, translatePath, useTranslations } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	image?: string;
	ogType?: string;
	noindex?: boolean;
	// Locales this page exists in. When set, hreflang alternate links are
	// emitted for each — only pass it for fully-localized pages (the index and
	// error pages), NOT the English-only legal/info pages.
	alternates?: readonly Lang[];
}

// Active locale comes from the URL (English at the root, others under /<lang>/).
const lang = getLangFromUrl(Astro.url);
const dir = dirFor(lang);
const htmlLang = HTML_LANG[lang];
const t = useTranslations(lang);

const {
	title = t.meta.indexTitle,
	description = t.meta.indexDescription,
	keywords = t.meta.indexKeywords,
	image = "/og-image.svg",
	ogType = "website",
	noindex = false,
	alternates,
} = Astro.props;

// Build absolute URLs for canonical + social tags. Astro.site comes from
// astro.config.mjs; fall back to the production domain if it is unset.
const siteOrigin = Astro.site?.origin ?? "https://attentivebrain.com";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin).href;
const imageURL = new URL(image, siteOrigin).href;

// hreflang alternates: for each locale this page exists in, the localized URL
// for the same route. Plus x-default → the English (default-locale) version.
// Lets search engines serve the right language and avoids duplicate-content
// penalties across the localized copies.
const route = stripLangPrefix(Astro.url.pathname);
const hreflangs = (alternates ?? []).map((l) => ({
	lang: HTML_LANG[l],
	href: new URL(translatePath(route, l), siteOrigin).href,
}));
const xDefaultHref = new URL(translatePath(route, defaultLang), siteOrigin).href;

// Structured data: describes the game to search engines so it can surface as
// a rich result for "brain game" / "focus game" queries. Localized copy.
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "attentivebrain",
	url: siteOrigin,
	inLanguage: htmlLang,
	applicationCategory: "GameApplication",
	operatingSystem: "Web browser",
	description,
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "USD",
	},
};
---

<!doctype html>
<html lang={htmlLang} dir={dir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary SEO -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
		<meta name="author" content="attentivebrain" />
		<link rel="canonical" href={canonicalURL} />

		<!-- hreflang alternates (fully-localized pages only) -->
		{hreflangs.map((h) => (
			<link rel="alternate" hreflang={h.lang} href={h.href} />
		))}
		{hreflangs.length > 0 && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}

		<!-- Open Graph (Facebook, LinkedIn, etc.) -->
		<meta property="og:site_name" content="attentivebrain" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageURL} />
		<meta property="og:image:alt" content="attentivebrain — a brain game to increase focus and attention span" />
		<meta property="og:locale" content={htmlLang.replace("-", "_")} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />

		<meta name="theme-color" content="#ffffff" />

		<!-- Structured data for rich results -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Apply the saved theme before first paint so there is no flash. -->
		<script is:inline>
			(() => {
				try {
					const saved = localStorage.getItem("focus-attention:theme");
					const dark = saved ? saved === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
					if (dark) document.documentElement.setAttribute("data-theme", "dark");
				} catch {}
			})();
		</script>

		<!-- Inter as the off-Apple fallback for SF Pro (per DESIGN.md) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap"
		/>
	</head>
	<body>
		<SiteHeader />
		<slot />
		<SiteFooter />
	</body>
</html>
