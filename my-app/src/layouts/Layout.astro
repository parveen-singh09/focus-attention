---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import type { Lang } from "../i18n/ui";
import { HTML_LANG, defaultLang, dirFor } from "../i18n/ui";
import { getLangFromUrl, stripLangPrefix, translatePath, useTranslations } from "../i18n/utils";

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
	image?: string;
	ogType?: string;
	noindex?: boolean;
	showFooter?: boolean;

	alternates?: readonly Lang[];
}

const lang = getLangFromUrl(Astro.url);
const dir = dirFor(lang);
const htmlLang = HTML_LANG[lang];
const t = useTranslations(lang);

const {
	title = t.meta.indexTitle,
	description = t.meta.indexDescription,
	keywords = t.meta.indexKeywords,
	image = "/og-image.svg",
	ogType = "website",
	noindex = false,
	showFooter = false,
	alternates,
} = Astro.props;

const siteOrigin = Astro.site?.origin ?? "https://attentivebrain.com";
const canonicalURL = new URL(Astro.url.pathname, siteOrigin).href;
const imageURL = new URL(image, siteOrigin).href;

const route = stripLangPrefix(Astro.url.pathname);
const hreflangs = (alternates ?? []).map((l) => ({
	lang: HTML_LANG[l],
	href: new URL(translatePath(route, l), siteOrigin).href,
}));
const xDefaultHref = new URL(translatePath(route, defaultLang), siteOrigin).href;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "attentivebrain",
	url: siteOrigin,
	inLanguage: htmlLang,
	applicationCategory: "GameApplication",
	operatingSystem: "Web browser",
	description,
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "USD",
	},
};
---

<!doctype html>
<html lang={htmlLang} dir={dir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="BrainFocus" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
		<meta name="author" content="attentivebrain" />
		<link rel="canonical" href={canonicalURL} />

		{hreflangs.map((h) => (
			<link rel="alternate" hreflang={h.lang} href={h.href} />
		))}
		{hreflangs.length > 0 && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}

		<meta property="og:site_name" content="attentivebrain" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={imageURL} />
		<meta property="og:image:alt" content="attentivebrain — a brain game to increase focus and attention span" />
		<meta property="og:locale" content={htmlLang.replace("-", "_")} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageURL} />

		<meta name="theme-color" content="#ffffff" />

		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<script is:inline>
			(() => {
				try {
					const saved = localStorage.getItem("focus-attention:theme");
					const dark = saved ? saved === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
					if (dark) document.documentElement.setAttribute("data-theme", "dark");
				} catch {}
			})();
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap"
		/>
	</head>
	<body>
		<SiteHeader />
		<slot />
		{showFooter && <SiteFooter />}
	</body>
</html>
